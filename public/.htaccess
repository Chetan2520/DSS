# Disable directory listing to prevent 403 errors
Options -Indexes

RewriteEngine On
RewriteBase /

# If the request is for a directory without a trailing slash, redirect to add it
# This helps Apache find the index.html inside the folder
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ $1/ [L,R=301]

# If the request is for a path that doesn't exist as a file, 
# and folder/index.html exists, redirect to the folder (with trailing slash)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.*[^/])$ /$1/ [L,R=301]

# Fallback for 404 errors
ErrorDocument 404 /404.html
